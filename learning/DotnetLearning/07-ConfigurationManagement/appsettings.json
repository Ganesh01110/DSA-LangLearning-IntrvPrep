{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Database": {
        "ConnectionString": "Server=localhost;Port=3306;Database=config_demo;User=root;Password=;",
        "Timeout": 30,
        "MaxRetries": 3
    },
    "ApiSettings": {
        "BaseUrl": "https://api.example.com",
        "ApiKey": "default-key-override-with-secrets",
        "Timeout": 30
    },
    "Features": {
        "EnableCache": true,
        "CacheExpirationMinutes": 60,
        "EnableDetailedErrors": false
    }
}